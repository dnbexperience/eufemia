{
  "extends": [
    "stylelint-config-recommended",
    "stylelint-config-standard-scss"
  ],
  "plugins": [
    "stylelint-scss",
    "./scripts/stylelint/plugins/token-name-policy.cjs",
    "./scripts/stylelint/plugins/no-unused-use.cjs",
    "./scripts/stylelint/plugins/dollar-variable-no-camel-case.cjs"
  ],
  "rules": {
    "scss/at-mixin-argumentless-call-parentheses": "always",
    "scss/double-slash-comment-empty-line-before": null,
    "scss/at-mixin-pattern": [
      "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      { "message": "Mixin names should be kebab-case (scss/at-mixin-pattern)" }
    ],
    "scss/at-function-pattern": [
      "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      {
        "message": "Function names should be kebab-case (scss/at-function-pattern)"
      }
    ],
    "scss/operator-no-newline-after": null,
    "scss/at-if-no-null": null,
    "scss/dollar-variable-pattern": null,
    "color-function-notation": "modern",
    "declaration-empty-line-before": null,
    "at-rule-empty-line-before": null,
    "media-feature-range-notation": "prefix",
    "declaration-block-no-redundant-longhand-properties": [
      true,
      { "ignoreShorthands": ["inset"] }
    ],
    "rule-empty-line-before": null,
    "at-rule-no-unknown": null,
    "selector-not-notation": null,
    "keyframes-name-pattern": null,
    "custom-property-pattern": null,
    "selector-class-pattern": null,
    "selector-id-pattern": null,
    "number-max-precision": null,
    "at-rule-disallowed-list": ["import"],
    "eufemia/token-name-policy": [
      true,
      {
        "themePrefixes": {
          "ui": "dnb",
          "sbanken": "sbanken",
          "carnegie": "carnegie"
        }
      }
    ],
    "eufemia/no-unused-use": true,
    "eufemia/dollar-variable-no-camel-case": true
  }
}
