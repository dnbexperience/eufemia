/*
* ToggleButton component
*
*/
.dnb-toggle-button {
  display: inline-flex;
  align-items: center;
  font-size: var(--font-size-small);
  line-height: var(--line-height-basis);
}
.dnb-toggle-button__inner {
  display: inline-flex;
  flex-direction: column;
}
.dnb-toggle-button__shell {
  position: relative;
  left: 0;
  user-select: none;
}
