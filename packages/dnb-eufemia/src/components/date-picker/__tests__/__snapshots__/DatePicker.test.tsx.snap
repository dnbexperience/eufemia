  /** Normal state **/
}
.dnb-checkbox__input:checked ~ .dnb-checkbox__gfx, .dnb-checkbox__input[data-checked=true] ~ .dnb-checkbox__gfx {
  opacity: 1;
  transform: scale(1);
  color: var(--checkbox-color-gfx-on);
}
