/* Uses design token. Should become standard. Should be integrated with --focus-ring- variables */
.dnb-form-status {
  --form-status-radius: 0.25rem;
  display: flex;
  opacity: 1;
}
.dnb-form-status__shell {
  --form-status-color-text: var(--token-color-text-neutral);
