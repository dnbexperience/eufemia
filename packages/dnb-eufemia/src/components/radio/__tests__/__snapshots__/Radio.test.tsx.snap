/*
* Radio component
*
*/
.dnb-radio {
  --radio-dot--medium: 0.75rem;
  --radio-dot--large: 1.125rem;
  --radio-width--medium: 1.5rem;
  --radio-height--medium: 1.5rem;
  --radio-width--large: 2rem;
  --radio-height--large: 2rem;
  --radio-border-inset--default: inset;
  --radio-border-width--default: 0.0625rem;
  --radio-color-dot-on--default: var(--token-color-background-selected);
  --radio-color-background--default: var(--token-color-background-neutral);
  --radio-color-border--default: var(
    --token-color-stroke-action-alternative
  );
  --radio-color-dot-on--disabled: var(
    --token-color-background-action-disabled
  );
  --radio-color-background--disabled: var(
    --token-color-background-neutral
  );
  --radio-color-border--disabled: var(
    --token-color-stroke-action-disabled
  );
  --radio-border-inset--active: inset;
  --radio-border-width--active: 0.0625rem;
  --radio-color-dot-on--active: var(
    --token-color-background-action-pressed
  );
  --radio-color-background--active: var(
    --token-color-background-action-pressed-subtle
  );
  --radio-color-border--active: var(--token-color-stroke-action-pressed);
  --radio-border-inset--hover: ;
  --radio-border-width--hover: 0.125rem;
  --radio-color-dot-on--hover: var(--token-color-background-action-hover);
  --radio-color-background--hover: var(
    --token-color-background-action-hover-subtle
  );
  --radio-color-border--hover: var(--token-color-stroke-action-hover);
  --radio-border-inset--focus: ;
  --radio-border-width--focus: 0.25rem;
  --radio-color-dot-on--focus: var(--token-color-background-action-focus);
  --radio-color-background--focus: var(
    --token-color-background-action-focus-subtle
  );
  --radio-color-border--focus: var(--token-color-stroke-action-focus);
  --radio-bounding--medium: 1.75, 1.5;
  --radio-bounding--large: 1.25, 1.12;
  display: inline-flex;
  flex-direction: column;
  font-size: var(--font-size-small);
  line-height: var(--line-height-basis);
}
.dnb-radio__inner {
  display: inline-flex;
  flex-direction: column;
  align-self: center;
}
.dnb-radio__shell {
  position: relative;
  user-select: none;
  display: flex;
  align-items: center;
  flex-shrink: 0;
  justify-content: center;
  width: var(--radio-width--medium);
  height: var(--radio-height--medium);
}
.dnb-radio__button, .dnb-radio__dot {
  position: absolute;
  z-index: 4;
}
.dnb-radio__button {
  box-shadow: var(--radio-border-inset, var(--radio-border-inset--default)) 0 0 0 var(--radio-border-width, var(--radio-border-width--default)) var(--radio-color-border, var(--radio-color-border--default));
  background-color: var(--radio-color-background, var(--radio-color-background--default));
  width: calc(var(--radio-width--medium) - 0.25rem);
  height: calc(var(--radio-height--medium) - 0.25rem);
  border-radius: var(--token-radius-full);
}
.dnb-radio--large .dnb-radio__button {
  width: var(--radio-width--large);
  height: var(--radio-height--large);
}
.dnb-radio__dot {
  width: var(--radio-dot--medium);
  height: var(--radio-dot--medium);
  border-radius: var(--token-radius-full);
  transition: opacity 200ms ease-out, transform 200ms ease-out;
}
.dnb-radio--large .dnb-radio__dot {
  width: var(--radio-dot--large);
  height: var(--radio-dot--large);
}
.dnb-radio__input {
  opacity: 0;
  position: absolute;
  top: auto;
  left: auto;
  z-index: 5;
  width: var(--radio-width--medium);
  height: var(--radio-height--medium);
  margin: 0;
  padding: 0;
  border: 0;
  transform: scale(var(--radio-bounding--medium));
}
.dnb-radio--large .dnb-radio__input {
  width: var(--radio-width--large);
  height: var(--radio-height--large);
  transform: scale(var(--radio-bounding--large));
}
.dnb-radio__input:not([disabled]) {
  cursor: pointer;
}
.dnb-radio__order {
  display: inline-flex;
  align-items: baseline;
}
.dnb-radio-group--column .dnb-radio__order {
  display: flex;
}
.dnb-radio__row {
  display: inline-flex;
}
.dnb-radio__suffix {
  order: 3;
}
