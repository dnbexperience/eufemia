}
.dnb-radio--label-position-right .dnb-radio__order .dnb-form-label {
  order: 2;
  padding-left: 0.5rem;
}
:not(.dnb-radio-group) > .dnb-form-label + .dnb-radio {
  vertical-align: top;
}
.dnb-radio .dnb-form-status {
  order: 4;
  margin-top: 0.375rem; /* 6/16 */
