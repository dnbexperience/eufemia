}
.dnb-radio + .dnb-form-status {
  margin-top: 0.5rem;
  margin-bottom: 1rem;
}
.dnb-radio > .dnb-form-status {
  transform: translateY(0.25rem); /* 4/16 */
}
.dnb-radio-group {
  --radio-group-row-gap: 0.5rem;
  --radio-group-column-gap: 1rem;
  display: inline-flex;
}
.dnb-radio-group, .dnb-radio-group__fieldset, .dnb-radio-group__shell {
  flex-grow: 1;
}
.dnb-radio-group fieldset:not([class*=space__top]) {
  margin-top: 0;
}
.dnb-radio-group fieldset:not([class*=space__bottom]) {
  margin-bottom: 0;
}
.dnb-radio-group fieldset:not([class*=space__left]) {
  margin-left: 0;
}
.dnb-radio-group fieldset:not([class*=space__right]) {
  margin-right: 0;
}
.dnb-radio-group fieldset {
  padding: 0;
  border: none;
}
.dnb-radio-group--column .dnb-radio {
  display: flex;
  margin-right: 0;
}
.dnb-radio-group .dnb-radio:last-of-type {
  margin-right: 0;
}
.dnb-radio-group__shell {
  display: flex;
  flex-wrap: wrap;
  column-gap: var(--radio-group-column-gap);
  row-gap: var(--radio-group-row-gap);
}
.dnb-radio-group__shell > .dnb-form-status {
  margin-top: 0;
  margin-bottom: 0;
}
.dnb-radio-group--column .dnb-radio-group__shell {
  flex-direction: column;
}
.dnb-radio {
  /*
   * Color scheme
   */
  /** Normal state **/
}
.dnb-radio__input:checked ~ .dnb-radio__button, .dnb-radio__input[data-checked=true] ~ .dnb-radio__button {
  --radio-border-width--default: 0.09375rem;
  --radio-border-width--active: 0.09375rem;
  --radio-color-border--default: var(--token-color-stroke-selected);
  --radio-color-background--default: var(
    --token-color-background-selected-subtle
  );
}
.dnb-radio__input:checked ~ .dnb-radio__dot, .dnb-radio__input[data-checked=true] ~ .dnb-radio__dot {
  background-color: var(--radio-color-dot-on, var(--radio-color-dot-on--default));
  opacity: 1;
  transform: scale(1);
}
.dnb-radio__input:not(:checked):not([data-checked=true]) ~ .dnb-radio__dot {
  opacity: 0;
  transform: scale(0.8);
}
.dnb-radio {
  /** Error state **/
}
.dnb-radio__status--error .dnb-radio__input ~ .dnb-radio__button {
  --radio-border-width--default: 0.0625rem;
  --radio-color-background--default: var(
    --token-color-background-error-subtle
  );
  --radio-color-border--default: var(--token-color-stroke-error);
}
.dnb-radio__status--error {
  --radio-color-dot-on--default: var(--token-color-background-error);
}
.dnb-radio {
  /** Hover state **/
}
.dnb-radio__input:hover ~ .dnb-radio__button {
  --radio-border-inset: var(--radio-border-inset--hover);
  --radio-border-width: var(--radio-border-width--hover);
  --radio-color-border: var(--radio-color-border--hover);
  --radio-color-background: var(--radio-color-background--hover);
}
.dnb-radio__input:hover ~ .dnb-radio__dot {
  --radio-color-dot-on: var(--radio-color-dot-on--hover);
}
.dnb-radio {
  /** Active state **/
}
.dnb-radio__input:active ~ .dnb-radio__button {
  --radio-border-inset: var(--radio-border-inset--active);
  --radio-border-width: var(--radio-border-width--active);
  --radio-color-border: var(--radio-color-border--active);
  --radio-color-background: var(--radio-color-background--active);
}
.dnb-radio__input:active ~ .dnb-radio__dot {
  --radio-color-dot-on: var(--radio-color-dot-on--active);
}
.dnb-radio {
  /** Focus state **/
}
html[data-whatinput=keyboard] .dnb-radio__input:focus ~ .dnb-radio__button {
  --radio-border-inset: var(--radio-border-inset--focus);
  --radio-border-width: var(--radio-border-width--focus);
  --radio-color-border: var(--radio-color-border--focus);
  --radio-color-background: var(--radio-color-background--focus);
}
html[data-whatinput=keyboard] .dnb-radio__input:focus ~ .dnb-radio__dot {
  --radio-color-dot-on: var(--radio-color-dot-on--focus);
}
.dnb-radio {
  /** Disabled state **/
}
.dnb-radio__input[disabled] ~ .dnb-radio__button {
  --radio-border-inset: var(--radio-border-inset--disabled);
  --radio-border-width: var(--radio-border-width--disabled);
  --radio-color-border: var(--radio-color-border--disabled);
}
.dnb-radio__input[disabled] ~ .dnb-radio__button:not(.dnb-skeleton) {
  --radio-color-background: var(--radio-color-background--disabled);
}
.dnb-radio__input[disabled] ~ .dnb-radio__dot {
  --radio-color-dot-on: var(--radio-color-dot-on--disabled);
}
.dnb-radio__input[disabled] ~ .dnb-radio__button.dnb-skeleton {
  --radio-color-border: var(--skeleton-color);
}
.dnb-radio__input[disabled] ~ .dnb-radio__button.dnb-skeleton::before {
  border-radius: 0;
}"
